# Copy to .env only for your local shell tooling. The Python server reads environment variables directly.
ROOMCARD_DB_HOST=localhost
ROOMCARD_DB_PORT=3306
ROOMCARD_DB_USER=roomcard
ROOMCARD_DB_PASSWORD=replace-with-a-long-random-password
ROOMCARD_DB_NAME=room_card_system
# Optional socket instead of host/port:
# ROOMCARD_DB_SOCKET=/run/mysqld/mysqld.sock

# Loopback is the safe default. Use 0.0.0.0 only on an isolated, trusted LAN.
ROOMCARD_BIND_HOST=127.0.0.1
ROOMCARD_PORT=8888
ROOMCARD_SESSION_TTL_SECONDS=3600
